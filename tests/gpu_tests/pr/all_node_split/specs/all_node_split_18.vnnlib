(declare-const X_0 Real)
(declare-const X_1 Real)

(declare-const Y_0 Real)
(declare-const Y_1 Real)

; Input constraints:
(assert (>= X_0 -1.0))
(assert (<= X_0 1.0))

(assert (>= X_1 -1.0))
(assert (<= X_1 1.0))


; Output constraints:

(assert (or
    (and (>= Y_0 10))
    (and (<= Y_0 -10))
    (and (>= Y_1 10))
    (and (<= Y_1 3))
))
